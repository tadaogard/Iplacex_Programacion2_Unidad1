<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#FFF8E1">

        <TextView
            android:id="@+id/textViewTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_pedido"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#5D4037"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/textViewBienvenida"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido al Restaurante de Gastronomia Chilena"
            android:textSize="14sp"
            android:textColor="#795548"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/textViewTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPastel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/textViewBienvenida"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imageViewPastel"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pastel_choclo"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/pastel_choclo" />

                <TextView
                    android:id="@+id/textViewNombrePastel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pastel_choclo"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5D4037"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewPastel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/textViewValorPastel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/valor_pastel"
                    android:textSize="16sp"
                    android:textColor="#795548"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewPastel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/textViewNombrePastel" />

                <TextView
                    android:id="@+id/textViewLabelCantidadPastel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad:"
                    android:textSize="14sp"
                    android:textColor="#5D4037"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewPastel"
                    app:layout_constraintTop_toBottomOf="@id/textViewValorPastel" />

                <EditText
                    android:id="@+id/editTextCantidadPastel"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="0"
                    android:textAlignment="center"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/textViewLabelCantidadPastel"
                    app:layout_constraintTop_toTopOf="@id/textViewLabelCantidadPastel"
                    app:layout_constraintBottom_toBottomOf="@id/textViewLabelCantidadPastel" />

                <TextView
                    android:id="@+id/textViewLabelSubtotalPastel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtotal"
                    android:textSize="14sp"
                    android:textColor="#5D4037"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewPastel"
                    app:layout_constraintTop_toBottomOf="@id/textViewLabelCantidadPastel" />

                <TextView
                    android:id="@+id/textViewSubtotalPastel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/textViewLabelSubtotalPastel"
                    app:layout_constraintBottom_toBottomOf="@id/textViewLabelSubtotalPastel" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardCazuela"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/cardPastel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imageViewCazuela"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/cazuela"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/cazuela" />

                <TextView
                    android:id="@+id/textViewNombreCazuela"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/cazuela"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5D4037"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewCazuela"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/textViewValorCazuela"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/valor_cazuela"
                    android:textSize="16sp"
                    android:textColor="#795548"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewCazuela"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/textViewNombreCazuela" />

                <TextView
                    android:id="@+id/textViewLabelCantidadCazuela"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad:"
                    android:textSize="14sp"
                    android:textColor="#5D4037"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewCazuela"
                    app:layout_constraintTop_toBottomOf="@id/textViewValorCazuela" />

                <EditText
                    android:id="@+id/editTextCantidadCazuela"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="0"
                    android:textAlignment="center"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/textViewLabelCantidadCazuela"
                    app:layout_constraintTop_toTopOf="@id/textViewLabelCantidadCazuela"
                    app:layout_constraintBottom_toBottomOf="@id/textViewLabelCantidadCazuela" />

                <TextView
                    android:id="@+id/textViewLabelSubtotalCazuela"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtotal"
                    android:textSize="14sp"
                    android:textColor="#5D4037"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/imageViewCazuela"
                    app:layout_constraintTop_toBottomOf="@id/textViewLabelCantidadCazuela" />

                <TextView
                    android:id="@+id/textViewSubtotalCazuela"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/textViewLabelSubtotalCazuela"
                    app:layout_constraintBottom_toBottomOf="@id/textViewLabelSubtotalCazuela" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardTotales"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#EFEBE9"
            app:layout_constraintTop_toBottomOf="@id/cardCazuela"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textViewLabelTotalSinPropina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_sin_propina"
                    android:textSize="16sp"
                    android:textColor="#5D4037"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/textViewTotalSinPropina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#5D4037"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/textViewLabelTotalSinPropina"
                    app:layout_constraintBottom_toBottomOf="@id/textViewLabelTotalSinPropina" />

                <View
                    android:id="@+id/divider"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="#BDBDBD"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textViewLabelTotalSinPropina"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <Switch
                    android:id="@+id/switchPropina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider" />

                <TextView
                    android:id="@+id/textViewLabelPropina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/incluir_propina"
                    android:textSize="14sp"
                    android:textColor="#5D4037"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/switchPropina"
                    app:layout_constraintTop_toTopOf="@id/switchPropina"
                    app:layout_constraintBottom_toBottomOf="@id/switchPropina" />

                <TextView
                    android:id="@+id/textViewLabelMontoPropina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/propina"
                    android:textSize="14sp"
                    android:textColor="#795548"
                    android:layout_marginTop="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/switchPropina" />

                <TextView
                    android:id="@+id/textViewMontoPropina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textSize="14sp"
                    android:textColor="#E65100"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/textViewLabelMontoPropina"
                    app:layout_constraintBottom_toBottomOf="@id/textViewLabelMontoPropina" />

                <View
                    android:id="@+id/divider2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="#BDBDBD"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textViewLabelMontoPropina"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/textViewLabelTotalFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_final"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#3E2723"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider2"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/textViewTotalFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#BF360C"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/textViewLabelTotalFinal"
                    app:layout_constraintBottom_toBottomOf="@id/textViewLabelTotalFinal" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>